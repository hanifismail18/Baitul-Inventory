# ═══════════════════════════════════════════
# FIREBASE CONFIGURATION
# ═══════════════════════════════════════════
# 1. Buka https://console.firebase.google.com
# 2. Pilih project kamu (atau buat baru)
# 3. Ke Project Settings > General > Your apps > Web
# 4. Copy nilai dari sana ke bawah
# 5. Simpan file ini sebagai .env.local (hapus .example)
# 6. Jalankan: npm run dev
# ═══════════════════════════════════════════

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyAbCdEfGhIjKlMnOpQrStUvWxYz12345678
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=nama-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=nama-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=nama-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# ═══════════════════════════════════════════
# SUPABASE CONFIGURATION
# ═══════════════════════════════════════════
# 1. Buka https://supabase.com
# 2. Pilih project kamu (atau buat baru)
# 3. Ke Project Settings > API
# 4. Copy Project URL dan anon/public key ke bawah
# 5. Simpan file ini sebagai .env.local (hapus .example)
# ═══════════════════════════════════════════

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

