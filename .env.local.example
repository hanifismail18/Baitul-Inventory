# ═══════════════════════════════════════════
# SUPABASE CONFIGURATION
# ═══════════════════════════════════════════
# 1. Buka https://supabase.com
# 2. Pilih project kamu (atau buat baru)
# 3. Ke Project Settings > API
# 4. Copy Project URL dan anon/public key ke bawah
# 5. Simpan file ini sebagai .env.local
# ═══════════════════════════════════════════

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ═══════════════════════════════════════════
# ADMIN CREDENTIALS (opsional)
# ═══════════════════════════════════════════
# Jika tidak diisi, fallback ke: paduka / password

NEXT_PUBLIC_ADMIN_ID=paduka
NEXT_PUBLIC_ADMIN_PASSWORD=password
